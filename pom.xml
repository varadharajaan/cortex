        <!-- ============================================================== -->
        <jacoco.line.coverage>0.80</jacoco.line.coverage>
        <jacoco.branch.coverage>0.80</jacoco.branch.coverage>
        <dependency-check.cvss-fail-threshold>8</dependency-check.cvss-fail-threshold>

        <!-- Skip flags wired into Maven profiles (Rule 21.6: NEVER skip in default). -->
