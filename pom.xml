        <micrometer.version>1.13.6</micrometer.version>
        <quickwit-client.version>0.8.0</quickwit-client.version>
        <!-- CloudEvents 1.0 envelope library, used by P4.4b
             (log-ingest-service outbox publisher / ADR-0026).
             cloudevents-bom manages cloudevents-core, cloudevents-api,
             cloudevents-spring, cloudevents-kafka. -->
        <cloudevents.version>4.0.1</cloudevents.version>
        <!-- Pinned to resolve transitive convergence between
             spring-cloud-starter-netflix-eureka-client paths
             (eureka-core->guava 33.0.0-jre vs netflix-eventbus->guava 14.0.1).
             Required by P3.0b (ADR-0016 / LD27). -->
        <guava.version>33.0.0-jre</guava.version>
        <!-- Pinned to resolve transitive convergence between Spring AI
             (spring-ai-template-st -> ST4 -> antlr-runtime 3.5.3) and
             Eureka client (netflix-eventbus -> netflix-infix -> antlr-runtime 3.4).
             Required by P3.3 (ADR-0018 / LD38). -->
        <antlr-runtime.version>3.5.3</antlr-runtime.version>

        <!-- Pinned to resolve transitive convergence between
             org.postgresql:postgresql 42.7.4 (checker-qual 3.42.0)
             and com.google.guava:guava 33.0.0-jre (checker-qual 3.41.0).
             Required by P4.0 (log-ingest-service Eureka + Postgres on
             the same classpath / LD27 convergence rule). -->
        <checker-qual.version>3.42.0</checker-qual.version>

        <!-- P14 Trivy image-scan backlog (#156). Override the Spring Boot
             3.3.x-managed versions of these transitive libs to their patched
             releases. Both are Spring-Boot-managed properties, so the BOM
             picks the override up everywhere on the classpath.
             - netty 4.1.135.Final: CVE-2025-24970 (netty-handler, fix
               4.1.118), CVE-2026-42583 (netty-codec, fix 4.1.133),
               CVE-2026-44249 / CVE-2026-45416 (fix 4.1.135).
             - tomcat 10.1.55: CVE-2025-24813 (tomcat-embed-core CRITICAL,
               fix 10.1.35). Stays in the 10.1.x line Boot 3.3.x uses. -->
        <netty.version>4.1.135.Final</netty.version>
        <tomcat.version>10.1.55</tomcat.version>

        <!-- P14 Trivy image-scan backlog (#156). jersey-client is transitive
             via spring-cloud-starter-netflix-eureka-client on every service.
             3.1.10 clears CVE-2025-12383 (CRITICAL). Spring-Boot-managed
             property, so the BOM applies it across the classpath. -->
        <jersey.version>3.1.10</jersey.version>

        <!-- P14 Trivy image-scan backlog (#156), second pass (CI surfaced
             these on the Kafka/Postgres services that the gateway image did
             not exercise). postgresql.version is Spring-Boot-managed.
             postgresql 42.7.11 clears CVE-2026-42198 (pgjdbc client-side DoS).
             kafka-clients and its transitive lz4-java are NOT bumped: the
             embedded `spring-kafka-test` ZK broker (Spring Kafka 3.2.x, locked
             by Boot 3.3.x) hard-requires kafka-clients 3.7.x (Kafka 3.8/3.9
             removed methods it calls), and the lz4-java patch only ships under
             the `at.yawk.lz4` fork. Both ride the locked kafka-clients 3.7.2
             subtree and are allowlisted in `.trivyignore` pending the Boot
             3.4+/Spring Kafka 3.3+ migration tracked in #156. -->
        <postgresql.version>42.7.11</postgresql.version>

        <!-- P14 Trivy image-scan backlog (#156). Not Spring-Boot-managed, so
             pinned via dependencyManagement below (both are transitive:
             xstream via netflix-eureka-client, bcprov via the security stack).
             - xstream 1.4.21: CVE-2024-47072 (DoS, fix 1.4.21).
             - bouncycastle 1.84: CVE-2026-5598 (bcprov-jdk18on private-key
               leakage via non-constant-time code, fix 1.84). -->
        <xstream.version>1.4.21</xstream.version>
        <bouncycastle.version>1.84</bouncycastle.version>

        <!-- Convergence pin from the P14 spring-ai 1.0.8 bump (#156):
             spring-ai 1.0.8 wants 2.2.30, springdoc 2.6.0 wants 2.2.22. -->
        <swagger-annotations.version>2.2.30</swagger-annotations.version>

        <!-- ============================================================== -->
        <!-- Plugins                                                         -->
