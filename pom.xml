<?xml version="1.0" encoding="UTF-8"?>
<!--
    CORTEX - parent pom (Rule A15.3 / Part 14).

    Cognitive Observability Runtime Telemetry EXchange.
    AI-Powered Intelligent Log Management System.

    Stack: Java 17 LTS, Spring Boot 3.3.x, Spring Cloud 2023.0.x,
           Spring AI 1.0.x, Spring for GraphQL (bundled).

    Modules are added incrementally per phase (P3..P9). The parent enforces:
      - Java 17 baseline
      - Mandatory Lombok + MapStruct + lombok-mapstruct-binding annotation
        processors (Rule A4.3 / 14.3)
      - dependency-check (CVSS >= 8 fails the build) (Rule B17 / 13.2)
      - CycloneDX SBOM on every package (Rule B17)
      - Checkstyle at error severity (Rule 0.1.6 universal Javadoc)
      - SpotBugs at high threshold (Rule 13.3)
      - JaCoCo with 80% line + branch on service/util (Rule 12.5 / 13.4)
      - Maven Enforcer: requireMavenVersion 3.9.0+, requireJavaVersion 17,
        dependencyConvergence, banDuplicatePomDependencyVersions
      - Reproducible builds (project.build.outputTimestamp)
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <!--
          Pinned to 3.3.13 (latest 3.3.x patch). Minimum 3.3.6 because Spring
          Cloud Gateway 4.1.6 (Spring Cloud 2023.0.4) added a call to
          `HttpHeaders.headerSet()`, which only exists in Spring Framework
          6.1.15+ (ships in Spring Boot 3.3.6+). Bumped 3.3.6 -> 3.3.13 in P14
          to clear the Trivy image-scan backlog (#156): 3.3.13 brings the
          patched 3.3.x BOM (spring-boot CVE-2025-22235 fix 3.3.11, plus the
          latest 6.1.x Spring Framework and 6.3.x Spring Security in the line).
          Staying inside the locked 3.3.x line per the plan; a 3.4+/3.5+
          migration (needed only for the residual Framework 6.2+/Security 6.5+
          CVEs) is a separate, approval-gated decision tracked in #156.
          Reference: spring-cloud/spring-cloud-gateway#3664 +
          Spring Cloud 2023.0.4 release notes.
        -->
        <version>3.3.13</version>
        <relativePath/>
    </parent>

    <groupId>io.cortex</groupId>
    <artifactId>cortex-parent</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>CORTEX :: Parent</name>
    <description>
        CORTEX - Cognitive Observability Runtime Telemetry EXchange.
        AI-Powered Intelligent Log Management System.
    </description>
    <url>https://github.com/varadharajaan/cortex</url>
    <inceptionYear>2026</inceptionYear>

    <licenses>
        <license>
            <name>Apache License 2.0</name>
            <url>https://www.apache.org/licenses/LICENSE-2.0</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <developers>
        <developer>
            <id>varadharajaan</id>
            <name>varadharajaan</name>
            <email>varathu09@gmail.com</email>
            <url>https://github.com/varadharajaan</url>
        </developer>
    </developers>

    <scm>
        <connection>scm:git:git://github.com/varadharajaan/cortex.git</connection>
        <developerConnection>scm:git:ssh://git@github.com/varadharajaan/cortex.git</developerConnection>
        <url>https://github.com/varadharajaan/cortex</url>
        <tag>HEAD</tag>
    </scm>

    <!-- Modules are added per phase. Empty for P0; first module lands in P2. -->
    <modules>
        <module>log-agent-lib</module>
        <module>log-gateway</module>
        <!-- P3.0b throwaway downstream stub (ADR-0016). Removed when
             log-ingest-service (P4) and log-query-service (P7-ish) land. -->
        <module>log-echo-service</module>
        <!-- Added in P4: log-ingest-service - validate, dedupe,
             enrich, queue, Postgres write. -->
        <module>log-ingest-service</module>
        <!-- Added in P5: log-processor-service - parse, classify,
             AI anomaly, fan-out to Loki + Quickwit. P5.0 ships the
             scaffold + Kafka consumer skeleton + AnomalyClassifier
             SPI stub + Micrometer counters. -->
        <module>log-processor-service</module>
        <!-- Added in P6: log-remediation-service - consume from
             cortex.anomalies.v1 (the P5.4 / ADR-0031 handoff topic)
             and dispatch remediation playbooks via Slack / PagerDuty
             / Jira adapters. P6.0 ships the scaffold + Kafka consumer
             of cortex.anomalies.v1 + RemediationDispatcher SPI stub +
             Micrometer counters. -->
        <module>log-remediation-service</module>
        <!-- Added in P7: log-indexer-service - Quickwit index admin
             owner + retention enforcement + per-tenant cardinality
             budgets. P7.0 ships the scaffold + QuickwitIndexAdmin
             SPI stub + NoopQuickwitIndexAdmin default + Micrometer
             counter. Real Quickwit HTTP admin lands in P7.1+. -->
        <module>log-indexer-service</module>
        <!-- Added in P8: log-monitoring-service - cross-service health
             aggregation owner + SLO budget engine. P8.0 ships the
             scaffold + ServiceHealthProbe SPI stub +
             NoopServiceHealthProbe default + Micrometer counter +
             MonitoringHealthIndicator. Real Eureka-actuator probe
             lands in P8.1+. -->
        <module>log-monitoring-service</module>
    </modules>

