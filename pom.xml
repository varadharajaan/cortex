            </dependency>

            <!-- Pinned to resolve transitive convergence between
                 spring-cloud-starter-netflix-eureka-client paths.
                 See ${guava.version} property comment. -->
            <dependency>
                <groupId>com.google.guava</groupId>
                <artifactId>guava</artifactId>
                <version>${guava.version}</version>
            </dependency>

            <!-- Pinned to resolve antlr-runtime convergence between Spring AI
                 (ST4 template engine) and Eureka client (netflix-eventbus).
                 See ${antlr-runtime.version} property comment. -->
            <dependency>
                <groupId>org.antlr</groupId>
                <artifactId>antlr-runtime</artifactId>
                <version>${antlr-runtime.version}</version>
            </dependency>

            <!-- Pinned to resolve checker-qual convergence between
                 postgresql 42.7.4 and guava 33.0.0-jre on the
                 log-ingest-service classpath (P4.0).
                 See ${checker-qual.version} property comment. -->
            <dependency>
                <groupId>org.checkerframework</groupId>
                <artifactId>checker-qual</artifactId>
                <version>${checker-qual.version}</version>
            </dependency>

            <!-- P14 Trivy backlog (#156): force the patched xstream onto
                 every classpath. xstream is transitive via
                 spring-cloud-starter-netflix-eureka-client. See
