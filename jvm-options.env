# CORTEX -- recommended JVM options (Rule B15 / 18.4).
# Source this from launch scripts; do NOT bake into images.

# Heap: container-aware sizing
-XX:+UseContainerSupport
-XX:MaxRAMPercentage=75.0
-XX:InitialRAMPercentage=50.0

# GC: ZGC default for low pause (Java 17)
-XX:+UseZGC

# Crash diagnostics
-XX:+HeapDumpOnOutOfMemoryError
-XX:HeapDumpPath=/var/log/cortex/heapdumps
-XX:+ExitOnOutOfMemoryError

# Determinism
-Duser.timezone=UTC
-Dfile.encoding=UTF-8
-Djava.net.preferIPv4Stack=true

# Spring AOT-friendly
-Dspring.aot.enabled=true

# JIT / class data sharing
-XX:+UseStringDeduplication
-Xshare:auto

# Networking
-Dio.netty.allocator.type=pooled
-Dio.netty.tryReflectionSetAccessible=true
