
# ============================================================================
# CORTEX -- .gitignore
# ============================================================================
# Rule A18.1: ignore build outputs, IDE files, logs, secrets, local datastores.
# Q9: ignore local workspace planning docs and per-session tracking files.
# ============================================================================

# ---- Maven / Java build outputs ---------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
.mvn/wrapper/maven-wrapper.jar

# ---- IDE -------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace
.project
.classpath
.settings/
.factorypath
.apt_generated/
.apt_generated_test/
nbproject/private/
bin/

# ---- OS --------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Logs ------------------------------------------------------------------
logs/
*.log
*.log.*
log/

# ---- Local datastores / containers -----------------------------------------
/tmp/
loki-data/
postgres-data/
redis-data/
rabbitmq-data/
minio-data/
quickwit-data/
ollama-data/
*.h2.db
*.sqlite

# ---- Secrets / env ---------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.jks
secrets/

# ---- Coverage / reports ----------------------------------------------------
jacoco.exec
**/site/
**/coverage/
**/spotbugs/
**/dependency-check-report*
cyclonedx-sbom.xml

# ---- Node (postman tooling / commitlint) -----------------------------------
node_modules/
package-lock.json
yarn.lock

# ---- Python (helper scripts) -----------------------------------------------
__pycache__/
*.pyc
.venv/

# ---- Terraform -------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
!*.tfvars.example

# ---- Ansible ---------------------------------------------------------------
*.retry
infra/ansible/.vault_pass

# ---- Helm ------------------------------------------------------------------
infra/helm/charts/**/charts/
infra/helm/charts/**/*.tgz

# ---- Workspace-local planning docs (Q9) ------------------------------------
# These guided the design but are NOT part of the cortex deliverable.
/agent-strict-rules-prompts.md
/ai-powered-log-management-system.md
/PLAN_MODE_PROMPT.md

# ---- Local-only tracking files (Q9, A1.5 override) -------------------------
# Per-session resumption files; live at root, never committed.
/plan.md
/checkpoint.md
/memory.md
/todo.md
/user-inputs-prompts.txt

# ---- Workspace-local Copilot context (Q9 interpretation) -------------------
# .github/copilot-instructions.md is workspace context for AI tooling,
# NOT part of the cortex repo. .github/workflows/, CODEOWNERS, and
# PULL_REQUEST_TEMPLATE.md ARE committed (required by Part 7.4 + B22).
/.github/copilot-instructions.md

# Local scratch files
.*.tmp
.create-issues.ps1
.cleanup-issues.ps1
.commit-batch.ps1
/scripts/

#.out files from local test runs (e.g. integration test outputs, replay logs, etc.)
# from any directory and subdirectories. This is a broad pattern, but .out files are typically not source files and are often generated as temporary outputs.
**/*.out

# also same for this pattern *output.txt, which is a common name for test outputs and logs.
**/*output.txt

# Part 26.10.4 — centralized logs / probe artifacts must not leak to repo root.
# Catches ad-hoc probe / boot-trace files like wiremock-probes.txt, eureka-boot.txt,
# kafka-probe.txt, schema-registry-boot.txt, etc.
**/*-probes.txt
**/*-probe.txt
**/*-boot.txt
**/*-boot.trace.txt

# local one-shot issue/PR body templates
.issue-*.md
.pr-*.md

# local detached-process PID registry (LD25 / LD45 / Part 26.1)
/pids.json

# LD86 + LD90 root-level scratch ban — utilities under /scripts/, PR/issue bodies
# under /logs/local/<phase>/. These patterns are a belt-and-braces guard so an
# accidental Set-Content / Move-Item leaving an artefact at the repo root cannot
# slip into a commit. Reviewed in Part 26.11.
/_*.ps1
/_*.psm1
/_*.txt
/_*.md
/PR_*.md
/PR-*.md
/pr-*.md
/PROMPT_*.md
/SCRATCH_*.md
/SCRATCH_*.txt
/scratch_*.ps1
