    {
      "name": "Anomalies Read API (P9.3a)",
      "description": "Direct remediation-service read API over the Postgres anomalies read model. Local live smoke seeds one anomaly through Kafka first, then passes tenant_id + anomaly_event_id to Newman so this folder proves the read model is populated end-to-end. Staging/prod runs can omit anomaly_event_id and still verify the tenant-scoped API shape.",
      "item": [
        {
          "name": "GET /api/v1/anomalies -> 200 tenant-scoped list",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "application/json" } ],
            "url": {
              "raw": "{{base_url}}/api/v1/anomalies?tenantId={{tenant_id}}&limit=10",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "v1", "anomalies" ],
              "query": [
                { "key": "tenantId", "value": "{{tenant_id}}" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('body is an array', function () { pm.expect(body).to.be.an('array'); });",
            "pm.test('limit respected', function () { pm.expect(body.length).to.be.at.most(10); });",
            "const expectedTenant = pm.environment.get('tenant_id');",
            "const expectedEventId = pm.environment.get('anomaly_event_id');",
            "if (expectedEventId) {",
            "    pm.test('seeded anomaly_event_id is returned', function () {",
            "        pm.expect(body.some(row => row.eventId === expectedEventId)).to.equal(true);",
            "    });",
            "}",
            "if (body.length > 0) {",
            "    const row = expectedEventId ? body.find(item => item.eventId === expectedEventId) : body[0];",
            "    pm.test('row has stable anomaly fields', function () {",
            "        pm.expect(row).to.have.property('tenantId');",
            "        pm.expect(row).to.have.property('eventId');",
            "        pm.expect(row).to.have.property('severity');",
            "        pm.expect(row).to.have.property('reason');",
            "        pm.expect(row).to.have.property('ts');",
            "        pm.expect(row).to.have.property('confidence');",
            "        pm.expect(row).to.have.property('anomalyType');",
            "        pm.expect(row).to.have.property('remediationKey');",
            "        pm.expect(row).to.have.property('receivedAt');",
            "    });",
            "    pm.test('row is scoped to requested tenant', function () { pm.expect(row.tenantId).to.equal(expectedTenant); });",
            "}"
          ] } } ]
        },
        {
          "name": "GET /api/v1/anomalies without tenantId -> 400",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "application/json" } ],
            "url": {
              "raw": "{{base_url}}/api/v1/anomalies?limit=10",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "v1", "anomalies" ],
              "query": [
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 400', function () { pm.response.to.have.status(400); });",
            "const body = pm.response.json();",
            "pm.test('validation error code', function () { pm.expect(body.errorCode).to.equal('VALIDATION_FAILED'); });",
            "pm.test('validation message present', function () { pm.expect(body.message).to.be.a('string').that.is.not.empty; });"
          ] } } ]
        }
      ]
    },
    {
      "name": "Metrics-Baseline",
      "description": "Snapshot the cortex_remediation_dispatched_total counter per channel BEFORE any Channel-Mock-Smoke calls. Reads ALL outcomes (dispatched + transient_failure + permanent_failure + skipped) and sums per channel so the baseline is robust to whichever Provider is configured.",
      "item": [
        {
          "name": "GET /actuator/prometheus baseline -> capture per-channel counters",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "text/plain" } ],
            "url": { "raw": "{{base_url}}/actuator/prometheus", "host": [ "{{base_url}}" ], "path": [ "actuator", "prometheus" ] }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', function () { pm.response.to.have.status(200); });",
            "const text = pm.response.text();",
            "function sumForChannel(channel) {",
            "    const re = new RegExp('^cortex_remediation_dispatched_total\\\\{[^}]*channel=\"' + channel + '\"[^}]*\\\\}\\\\s+([0-9.eE+-]+)$', 'gm');",
            "    let total = 0; let m;",
            "    while ((m = re.exec(text)) !== null) { total += parseFloat(m[1]); }",
            "    return total;",
            "}",
            "pm.environment.set('dispatched_baseline_slack', String(sumForChannel('slack')));",
            "pm.environment.set('dispatched_baseline_pagerduty', String(sumForChannel('pagerduty')));",
            "pm.environment.set('dispatched_baseline_jira', String(sumForChannel('jira')));",
            "pm.test('baseline slack counter recorded', function () { pm.expect(pm.environment.get('dispatched_baseline_slack')).to.be.a('string'); });",
            "pm.test('baseline pagerduty counter recorded', function () { pm.expect(pm.environment.get('dispatched_baseline_pagerduty')).to.be.a('string'); });",
            "pm.test('baseline jira counter recorded', function () { pm.expect(pm.environment.get('dispatched_baseline_jira')).to.be.a('string'); });"
          ] } } ]
        }
      ]
    },
    {
      "name": "Channel-Mock-Smoke (WireMock-shaped POSTs)",
      "description": "Fires the exact channel-shaped POSTs that scripts/smoke-p6-1a.ps1 + the *WireMockIT tests use against the local WireMock on :8094. These prove the on-the-wire payload contract end-to-end WITHOUT touching real Slack / PagerDuty / Jira -- runs OFFLINE. Skipped when {{wiremock_base_url}} is empty (staging / prod environments). LD23 mirror with the smoke script: same body shape, same headers, same expected status. The path under /__admin/scenarios is reset between runs by the smoke; this folder issues fresh runIds via {{$guid}} so it composes safely with concurrent runs.",
      "item": [
        {
          "name": "POST WireMock Slack webhook -> 200 ok (happy)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"[cortex-remediation-postman] anomaly evt-PM-{{$guid}} from log-processor (env=local tenant={{tenant_id}})\",\n  \"username\": \"cortex-remediation-postman\"\n}"
            },
            "url": {
              "raw": "{{wiremock_base_url}}/services/SMK-postman/B/X",
              "host": [ "{{wiremock_base_url}}" ],
              "path": [ "services", "SMK-postman", "B", "X" ]
            }
          },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "if (!pm.environment.get('wiremock_base_url')) { pm.execution.skipRequest(); }"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('status one of 200/404 (200 when smoke stub is live, 404 when scenario is exhausted)', function () { pm.expect([200, 404]).to.include(pm.response.code); });"
            ] } }
          ]
        },
        {
          "name": "POST WireMock PagerDuty enqueue -> 202 accepted (happy)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routing_key\": \"00000000000000000000000000000000\",\n  \"event_action\": \"trigger\",\n  \"dedup_key\": \"{{tenant_id}}:evt-PM-{{$guid}}\",\n  \"payload\": {\n    \"summary\": \"[cortex-remediation-postman] anomaly evt-PM (env=local)\",\n    \"source\": \"cortex-remediation\",\n    \"severity\": \"error\"\n  }\n}"
            },
            "url": {
              "raw": "{{wiremock_base_url}}/v2/enqueue",
              "host": [ "{{wiremock_base_url}}" ],
              "path": [ "v2", "enqueue" ]
            }
          },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "if (!pm.environment.get('wiremock_base_url')) { pm.execution.skipRequest(); }"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('status one of 202/404 (202 when smoke stub is live, 404 when stub absent)', function () { pm.expect([202, 404]).to.include(pm.response.code); });"
            ] } }
          ]
        },
        {
          "name": "POST WireMock Jira createIssue -> 201 created (happy)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Basic {{jira_basic_auth_b64}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": {\n    \"project\": { \"key\": \"OPS\" },\n    \"summary\": \"[cortex-remediation-postman] anomaly evt-PM (env=local)\",\n    \"issuetype\": { \"name\": \"Bug\" },\n    \"labels\": [ \"cortex-remediation\", \"tenant:{{tenant_id}}\", \"anomaly-severity-error\" ]\n  }\n}"
            },
            "url": {
              "raw": "{{wiremock_base_url}}/rest/api/3/issue",
              "host": [ "{{wiremock_base_url}}" ],
              "path": [ "rest", "api", "3", "issue" ]
            }
          },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "if (!pm.environment.get('wiremock_base_url')) { pm.execution.skipRequest(); }"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('status one of 201/404 (201 when smoke stub is live, 404 when stub absent)', function () { pm.expect([201, 404]).to.include(pm.response.code); });"
            ] } }
          ]
        }
      ]
    },
    {
      "name": "Metrics-After",
      "description": "Re-scrape /actuator/prometheus. Postman/Newman alone CANNOT publish to the Kafka topic, so this folder verifies the counter family is still exposed + non-decreasing -- NOT a strict delta assertion. The closed-loop delta assertion lives in scripts/smoke-p6-1a.ps1 (Leg B) which publishes through Kafka end-to-end. LD23 split-of-concerns: smoke = e2e delta, Newman = HTTP contract.",
      "item": [
        {
          "name": "GET /actuator/prometheus -> family still present + counters monotonically non-decreasing",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "text/plain" } ],
            "url": { "raw": "{{base_url}}/actuator/prometheus", "host": [ "{{base_url}}" ], "path": [ "actuator", "prometheus" ] }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', function () { pm.response.to.have.status(200); });",
            "const text = pm.response.text();",
            "pm.test('family cortex_remediation_dispatched_total still exposed', function () { pm.expect(text).to.include('cortex_remediation_dispatched_total'); });",
            "function sumForChannel(channel) {",
            "    const re = new RegExp('^cortex_remediation_dispatched_total\\\\{[^}]*channel=\"' + channel + '\"[^}]*\\\\}\\\\s+([0-9.eE+-]+)$', 'gm');",
            "    let total = 0; let m;",
            "    while ((m = re.exec(text)) !== null) { total += parseFloat(m[1]); }",
            "    return total;",
            "}",
            "const baseSlack = parseFloat(pm.environment.get('dispatched_baseline_slack') || '0');",
            "const basePD = parseFloat(pm.environment.get('dispatched_baseline_pagerduty') || '0');",
            "const baseJira = parseFloat(pm.environment.get('dispatched_baseline_jira') || '0');",
            "const nowSlack = sumForChannel('slack');",
            "const nowPD = sumForChannel('pagerduty');",
            "const nowJira = sumForChannel('jira');",
            "pm.test('slack counter monotonically non-decreasing', function () { pm.expect(nowSlack).to.be.at.least(baseSlack); });",
            "pm.test('pagerduty counter monotonically non-decreasing', function () { pm.expect(nowPD).to.be.at.least(basePD); });",
            "pm.test('jira counter monotonically non-decreasing', function () { pm.expect(nowJira).to.be.at.least(baseJira); });"
          ] } } ]
        }
      ]
    }
  ]
}
