{
  "info": {
    "name": "CORTEX :: log-gateway",
    "_postman_id": "c0a1f3b0-0000-4000-8000-c0a1f3b0e001",
    "description": "Postman collection for the CORTEX log-gateway service. Mirrors `scripts/smoke-p3-1.ps1` (Part 21 Levels 1-6) for every check expressible over HTTP. Folder order matters: Auth runs first to populate `jwt` + `refresh_token` + `consumed_refresh_token`, then Health, Admin, Error Scenarios.\n\nEnvironments:\n- `log-gateway.postman_environment_local.json` (http://localhost:8080)\n- `log-gateway.postman_environment_staging.json`\n- `log-gateway.postman_environment_prod.json`\n\nSee `postman/README.md` for run instructions (Newman CLI).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    {
      "key": "request_id",
      "value": "{{$guid}}",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('request_id', pm.variables.replaceIn('{{$guid}}'));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('echoed X-Request-Id matches', function () {",
          "  const sent = pm.collectionVariables.get('request_id');",
          "  const echoed = pm.response.headers.get('X-Request-Id');",
          "  if (echoed) { pm.expect(echoed).to.eql(sent); }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/login (good credentials)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{auth_username}}\",\n  \"password\": \"{{auth_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Exchanges username + password for an access + refresh JWT pair. Stashes both tokens into environment variables `jwt`, `refresh_token`, AND `consumed_refresh_token` (the latter is replayed in the single-use test below)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('body has access + refresh tokens', () => {",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.tokenType).to.eql('Bearer');",
                  "});",
                  "pm.test('accessExpiresAt is ISO-8601 in the future', () => {",
                  "  pm.expect(body.accessExpiresAt).to.be.a('string').and.match(/T.*Z$/);",
                  "  pm.expect(new Date(body.accessExpiresAt).getTime()).to.be.greaterThan(Date.now());",
                  "});",
                  "pm.test('access token header alg is HS256', () => {",
                  "  const parts = body.accessToken.split('.');",
                  "  pm.expect(parts).to.have.lengthOf(3);",
                  "  const b64url = (s) => s.replace(/-/g,'+').replace(/_/g,'/');",
                  "  const headerJson = JSON.parse(Buffer.from(b64url(parts[0]), 'base64').toString('utf8'));",
                  "  pm.expect(headerJson.alg).to.eql('HS256');",
                  "});",
                  "pm.environment.set('jwt', body.accessToken);",
                  "pm.environment.set('refresh_token', body.refreshToken);",
                  "pm.environment.set('consumed_refresh_token', body.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login (blank password -> 400 VALIDATION_FAILED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{auth_username}}\",\n  \"password\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Bean Validation negative path: blank password returns 400 RFC 7807 ProblemDetail with errorCode=VALIDATION_FAILED."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "const body = pm.response.json();",
                  "pm.test('errorCode is VALIDATION_FAILED', () => pm.expect(body.errorCode).to.eql('VALIDATION_FAILED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login (bad credentials -> 401 UNAUTHENTICATED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{auth_username}}\",\n  \"password\": \"definitely-wrong\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Negative path: wrong password returns 401 with errorCode=UNAUTHENTICATED."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('errorCode is UNAUTHENTICATED', () => pm.expect(body.errorCode).to.eql('UNAUTHENTICATED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/refresh (rotates pair)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Rotates the access + refresh token pair (rule B7.5 single-use). The previous refresh token is consumed; `consumed_refresh_token` env var still holds it for the replay test below. New tokens replace `jwt` and `refresh_token`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('new tokens differ from previous', () => {",
                  "  pm.expect(body.accessToken).to.not.eql(pm.environment.get('jwt'));",
                  "  pm.expect(body.refreshToken).to.not.eql(pm.environment.get('refresh_token'));",
                  "});",
                  "pm.test('accessExpiresAt is ISO-8601 in the future', () => {",
                  "  pm.expect(body.accessExpiresAt).to.be.a('string').and.match(/T.*Z$/);",
                  "  pm.expect(new Date(body.accessExpiresAt).getTime()).to.be.greaterThan(Date.now());",
                  "});",
                  "pm.environment.set('jwt', body.accessToken);",
                  "pm.environment.set('refresh_token', body.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/refresh (replay consumed -> 401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{consumed_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Replays the original refresh token (already consumed by the rotation above). Expects 401 UNAUTHENTICATED -- single-use rule B7.5."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('errorCode is UNAUTHENTICATED', () => pm.expect(body.errorCode).to.eql('UNAUTHENTICATED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/health (WITH bearer -> 200)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "Round-trips the freshly rotated access token through the resource-server filter chain. Same path is public, so this also proves the bearer is parsed without error."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('body has status UP', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/health (tampered bearer -> 401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" },
              { "key": "Authorization", "value": "Bearer {{jwt}}X" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "Appends junk to the signature segment. NimbusJwtDecoder fails HMAC verification -> 401 UNAUTHENTICATED."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
