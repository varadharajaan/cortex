    {
      "name": "Error Scenarios",
      "item": [
        {
          "name": "GET unknown path WITH bearer -> 404 NOT_FOUND",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/does-not-exist",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "does-not-exist"]
            },
            "description": "Authenticated request to an unmapped path. Spring 6 throws NoResourceFoundException; GlobalExceptionHandler maps it to 404 + RFC 7807 with errorCode=NOT_FOUND (commit 5e811bf). Without that handler this returns 500."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));",
                  "const body = pm.response.json();",
                  "pm.test('errorCode is NOT_FOUND', () => pm.expect(body.errorCode).to.eql('NOT_FOUND'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET unknown path NO bearer -> 401",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/does-not-exist",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "does-not-exist"]
            },
            "description": "Same unknown path, no bearer. Resource-server filter chain denies anonymous access -> 401, never reaches the dispatcher."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    }
