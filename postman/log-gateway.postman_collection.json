{
  "info": {
    "name": "CORTEX :: log-gateway",
    "_postman_id": "c0a1f3b0-0000-4000-8000-c0a1f3b0e001",
    "description": "Postman collection for the CORTEX log-gateway service. Edge endpoints (auth, NL->LogQL, reverse proxy) plus admin and error scenarios.\n\nEnvironments:\n- `log-gateway.postman_environment_local.json` (http://localhost:8080)\n- `log-gateway.postman_environment_staging.json`\n- `log-gateway.postman_environment_prod.json`\n\nSee `postman/README.md` for run instructions (Newman CLI).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    {
      "key": "request_id",
      "value": "{{$guid}}",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('request_id', pm.variables.replaceIn('{{$guid}}'));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('echoed X-Request-Id matches', function () {",
          "  const sent = pm.collectionVariables.get('request_id');",
          "  const echoed = pm.response.headers.get('X-Request-Id');",
          "  if (echoed) { pm.expect(echoed).to.eql(sent); }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{auth_username}}\",\n  \"password\": \"{{auth_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Exchanges username + password for an access + refresh JWT pair. Stashes both tokens into environment variables `jwt` and `refresh_token` for chained requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('body has access + refresh tokens', () => {",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.tokenType).to.eql('Bearer');",
                  "});",
                  "pm.environment.set('jwt', body.accessToken);",
                  "pm.environment.set('refresh_token', body.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Rotates the access + refresh token pair. The previous refresh token is consumed (single-use, rule B7.5). New tokens replace `jwt` and `refresh_token` in the environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('new tokens differ from previous', () => {",
                  "  pm.expect(body.accessToken).to.not.eql(pm.environment.get('jwt'));",
                  "  pm.expect(body.refreshToken).to.not.eql(pm.environment.get('refresh_token'));",
                  "});",
                  "pm.environment.set('jwt', body.accessToken);",
                  "pm.environment.set('refresh_token', body.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login (bad credentials)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{auth_username}}\",\n  \"password\": \"definitely-wrong\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Negative path: wrong password returns 401 with errorCode=UNAUTHENTICATED."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('errorCode is UNAUTHENTICATED', () => pm.expect(body.errorCode).to.eql('UNAUTHENTICATED'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/v1/health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "Public liveness endpoint. Returns 200 with {status, service, environment, timestamp}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('body has status UP', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('UP');",
                  "  pm.expect(body.service).to.eql('log-gateway');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/actuator/health",
              "host": ["{{base_url}}"],
              "path": ["actuator", "health"]
            },
            "description": "Spring Boot actuator health probe. Public in dev; restricted in prod."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /actuator/info",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/actuator/info",
              "host": ["{{base_url}}"],
              "path": ["actuator", "info"]
            }
          }
        },
        {
          "name": "GET /actuator/prometheus",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/plain" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/actuator/prometheus",
              "host": ["{{base_url}}"],
              "path": ["actuator", "prometheus"]
            }
          }
        }
      ]
    },
    {
      "name": "Error Scenarios",
      "item": [
        {
          "name": "GET unknown path returns 401 or 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/does-not-exist",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "does-not-exist"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401 or 404', () => {",
                  "  pm.expect([401, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
