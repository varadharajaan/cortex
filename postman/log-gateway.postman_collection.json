    {
      "name": "NlQuery",
      "description": "P3.3 / ADR-0018: Spring AI ChatClient -> Ollama (WireMock-stubbed) natural-language to LogQL translation. Three outcome paths are exercised: happy (200 + valid {logql,confidence,explanation}), schema-miss (422 + NL_QUERY_INVALID), refusal (422 + NL_QUERY_REFUSED). The model output is routed by WireMock via a `trigger:HAPPY|SCHEMA_MISS|REFUSAL` substring embedded in the user prompt -- see infra/local/wiremock/mappings. The sub-bucket-exhaustion 429 case is covered by scripts/smoke-p3-3.ps1 instead because it requires deterministic Redis state; run Postman BEFORE RateLimit (and reset cortex:rl:nlq:* keys between the smoke and the newman run).",
      "item": [
        {
          "name": "POST /api/v1/query/nl HAPPY -> 200 + valid {logql,confidence,explanation}",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"prompt\":\"trigger:HAPPY find error logs in payment service in last 1h\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/query/nl",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "query", "nl"]
            },
            "description": "Authenticated NL translate. WireMock returns a happy /api/chat response whose assistant message content parses to {logql,confidence,explanation}. The gateway forwards the parsed DTO unchanged after passing the ADR-0018 validator (LogQL leading token, confidence in [0,1] and >= floor, no refusal marker)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('body has non-empty logql', () => {",
                  "  pm.expect(body.logql).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('logql starts with { or known LogQL leading token', () => {",
                  "  const trimmed = body.logql.trimStart();",
                  "  const tokens = ['{','count_over_time','rate','sum','avg','max','min','topk','bottomk'];",
                  "  pm.expect(tokens.some(t => trimmed.startsWith(t))).to.be.true;",
                  "});",
                  "pm.test('confidence is a number in [0,1]', () => {",
                  "  pm.expect(body.confidence).to.be.a('number');",
                  "  pm.expect(body.confidence).to.be.at.least(0);",
                  "  pm.expect(body.confidence).to.be.at.most(1);",
                  "});",
                  "pm.test('explanation is non-empty', () => {",
