    {
      "name": "Metrics-Baseline",
      "description": "Snapshot the counter baselines into env vars BEFORE the Pipeline folder publishes anything. Metrics-After uses these to assert deltas.",
      "item": [
        {
          "name": "GET /actuator/prometheus baseline -> capture counters",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "text/plain" } ],
            "url": { "raw": "{{base_url}}/actuator/prometheus", "host": [ "{{base_url}}" ], "path": [ "actuator", "prometheus" ] }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', function () { pm.response.to.have.status(200); });",
            "const text = pm.response.text();",
            "function sumFamily(metricName) {",
            "    const re = new RegExp('^' + metricName.replace(/\\./g, '_') + '(?:\\\\{[^}]*\\\\})?\\\\s+([0-9.eE+-]+)$', 'gm');",
            "    let total = 0; let m;",
            "    while ((m = re.exec(text)) !== null) { total += parseFloat(m[1]); }",
            "    return total;",
            "}",
            "function valueWithTag(metricName, tagPair) {",
            "    const re = new RegExp('^' + metricName.replace(/\\./g, '_') + '\\\\{[^}]*' + tagPair + '[^}]*\\\\}\\\\s+([0-9.eE+-]+)$', 'm');",
            "    const m = re.exec(text); return m ? parseFloat(m[1]) : 0;",
            "}",
            "const consumed = sumFamily('cortex.processor.events.consumed_total');",
            "const anomaly = valueWithTag('cortex.processor.events.classified_total', 'outcome=\"anomaly\"');",
            "const lokiPub = sumFamily('cortex.processor.sink.loki.published_total');",
            "const quickwitPub = sumFamily('cortex.processor.sink.quickwit.published_total');",
            "const anomaliesPub = sumFamily('cortex.processor.anomalies.published_total');",
            "pm.environment.set('consumed_baseline', String(consumed));",
            "pm.environment.set('classified_anomaly_baseline', String(anomaly));",
            "pm.environment.set('sink_loki_published_baseline', String(lokiPub));",
            "pm.environment.set('sink_quickwit_published_baseline', String(quickwitPub));",
            "pm.environment.set('anomalies_published_baseline', String(anomaliesPub));",
            "pm.test('baseline consumed counter recorded', function () { pm.expect(pm.environment.get('consumed_baseline')).to.be.a('string'); });",
            "pm.test('baseline anomaly counter recorded', function () { pm.expect(pm.environment.get('classified_anomaly_baseline')).to.be.a('string'); });",
            "pm.test('baseline sink loki + quickwit recorded (zero when sinks disabled is fine)', function () { pm.expect(pm.environment.get('sink_loki_published_baseline')).to.be.a('string'); pm.expect(pm.environment.get('sink_quickwit_published_baseline')).to.be.a('string'); });",
            "pm.test('baseline anomalies_published_total recorded (P5.4 / ADR-0031, bootstrap-registered so always present)', function () { pm.expect(pm.environment.get('anomalies_published_baseline')).to.be.a('string'); });"
          ] } } ]
        }
      ]
    },
    {
      "name": "Pipeline (gateway -> ingest -> Kafka -> processor)",
      "description": "End-to-end smoke: publish a high-severity log via the gateway, gateway rewrites to /api/v1/ingest/batch, ingest persists + writes outbox row, poller publishes CloudEvent to cortex.logs.events.v1, processor consumer parses + classifies (spring-ai classifier hits WireMock-stubbed Ollama returning anomaly=true), counters tick. The next folder (Metrics-After) reads /actuator/prometheus on the processor and asserts the deltas.",
      "item": [
        {
          "name": "POST /api/v1/logs/batch (anomaly-looking entry) -> 202",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entries\": [\n    {\n      \"timestamp\": \"{{$isoTimestamp}}\",\n      \"level\": \"ERROR\",\n      \"service\": \"demo-app\",\n      \"message\": \"OutOfMemoryError: Java heap space at io.cortex.demo.LoadGenerator.run(LoadGenerator.java:42) -- p5-2a newman pipeline {{$guid}}\",\n      \"labels\": { \"env\": \"local\" }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{gateway_base_url}}/api/v1/logs/batch",
              "host": [ "{{gateway_base_url}}" ],
              "path": [ "api", "v1", "logs", "batch" ]
            }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 202', function () { pm.response.to.have.status(202); });",
            "const body = pm.response.json();",
            "pm.test('receivedCount == 1', function () { pm.expect(body.receivedCount).to.equal(1); });",
            "pm.test('receivedAt is ISO string', function () { pm.expect(body.receivedAt).to.be.a('string').that.matches(/^\\d{4}-\\d{2}-\\d{2}T/); });",
            "pm.test('X-Request-Id echoed', function () { pm.expect(pm.response.headers.get('X-Request-Id')).to.equal(pm.variables.get('request_id')); });"
          ] } } ]
        },
        {
          "name": "Settle delay (sleep 20s while outbox poller + Kafka consumer drain)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "application/json" } ],
            "url": { "raw": "{{base_url}}/actuator/health", "host": [ "{{base_url}}" ], "path": [ "actuator", "health" ] }
          },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "// Outbox poller has fixed-delay=1s but backoff-max=5min when PENDING is empty.",
              "// 20s is enough to ride out a typical backoff cycle in a freshly idle stack.",
              "const wait = 20000;",
              "const start = Date.now();",
              "while (Date.now() - start < wait) { /* busy-wait so Newman blocks; setTimeout is not honored synchronously */ }"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('processor still healthy after settle', function () { pm.response.to.have.status(200); });"
            ] } }
          ]
        }
      ]
    },
    {
      "name": "Metrics-After",
      "description": "Re-scrape /actuator/prometheus and assert the Pipeline payload incremented the consumed + classified-anomaly counters above the baseline captured in Metrics-Baseline.",
      "item": [
        {
          "name": "GET /actuator/prometheus delta -> consumed and classified{outcome=anomaly} both ticked",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "text/plain" } ],
            "url": { "raw": "{{base_url}}/actuator/prometheus", "host": [ "{{base_url}}" ], "path": [ "actuator", "prometheus" ] }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', function () { pm.response.to.have.status(200); });",
            "const text = pm.response.text();",
            "function sumFamily(metricName) {",
            "    const re = new RegExp('^' + metricName.replace(/\\./g, '_') + '(?:\\\\{[^}]*\\\\})?\\\\s+([0-9.eE+-]+)$', 'gm');",
            "    let total = 0; let m;",
            "    while ((m = re.exec(text)) !== null) { total += parseFloat(m[1]); }",
            "    return total;",
            "}",
            "function valueWithTag(metricName, tagPair) {",
            "    const re = new RegExp('^' + metricName.replace(/\\./g, '_') + '\\\\{[^}]*' + tagPair + '[^}]*\\\\}\\\\s+([0-9.eE+-]+)$', 'm');",
            "    const m = re.exec(text); return m ? parseFloat(m[1]) : 0;",
            "}",
            "const consumedNow = sumFamily('cortex.processor.events.consumed_total');",
            "const anomalyNow = valueWithTag('cortex.processor.events.classified_total', 'outcome=\"anomaly\"');",
            "const lokiNow = sumFamily('cortex.processor.sink.loki.published_total');",
            "const quickwitNow = sumFamily('cortex.processor.sink.quickwit.published_total');",
            "const anomaliesNow = sumFamily('cortex.processor.anomalies.published_total');",
            "const consumedBase = parseFloat(pm.environment.get('consumed_baseline'));",
            "const anomalyBase = parseFloat(pm.environment.get('classified_anomaly_baseline'));",
            "const lokiBase = parseFloat(pm.environment.get('sink_loki_published_baseline') || '0');",
            "const quickwitBase = parseFloat(pm.environment.get('sink_quickwit_published_baseline') || '0');",
            "const anomaliesBase = parseFloat(pm.environment.get('anomalies_published_baseline') || '0');",
            "pm.test('consumed_total strictly increased (>= +1)', function () { pm.expect(consumedNow - consumedBase).to.be.at.least(1); });",
            "pm.test('classified_total{outcome=anomaly} strictly increased (>= +1)', function () { pm.expect(anomalyNow - anomalyBase).to.be.at.least(1); });",
            "// P5.4 / ADR-0031: anomalies_published_total counter is bootstrap-registered, so the family is always present in the scrape -- delta is asserted unconditionally.",
            "pm.test('cortex.processor.anomalies.published_total strictly increased (>= +1) (P5.4 / ADR-0031)', function () { pm.expect(anomaliesNow - anomaliesBase).to.be.at.least(1); });",
            "// Sink counters are only asserted when the sink family is registered on the scrape (i.e. the sink bean loaded because cortex.processor.sinks.{loki|quickwit}.enabled=true).",
            "if (text.includes('cortex_processor_sink_loki_published_total')) {",
            "    pm.test('sink loki published_total strictly increased (>= +1)', function () { pm.expect(lokiNow - lokiBase).to.be.at.least(1); });",
            "}",
            "if (text.includes('cortex_processor_sink_quickwit_published_total')) {",
            "    pm.test('sink quickwit published_total strictly increased (>= +1)', function () { pm.expect(quickwitNow - quickwitBase).to.be.at.least(1); });",
            "}"
          ] } } ]
        }
      ]
    },
    {
      "name": "Error Scenarios",
      "description": "Negative-path coverage per Part 26.3.",
      "item": [
        {
          "name": "GET /actuator/no-such-endpoint -> 404",
