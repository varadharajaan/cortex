# ============================================================================
# CORTEX -- .gitattributes
# Enforce LF line endings on all text files (Rule A0.5).
# ============================================================================

* text=auto eol=lf

# Explicitly text
*.java     text eol=lf
*.xml      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.sql      text eol=lf
*.properties text eol=lf
*.sh       text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Windows-native scripts keep CRLF
*.cmd      text eol=crlf
*.bat      text eol=crlf
*.ps1      text eol=crlf

# Maven wrapper must be LF + executable on POSIX CI runners
mvnw       text eol=lf

# Binary
*.jar      binary
*.png      binary
*.jpg      binary
*.gif      binary
*.ico      binary
*.zip      binary
*.gz       binary