<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    CORTEX - Checkstyle configuration.

    Enforces:
      - ASCII only (Rule A0.1)
      - 120-char Java line limit (Rule A0.6)
      - Constructor injection only (Rule 14.1) - enforced via SuppressionFilter
        + custom check for @Autowired on fields
      - No System.out.println (Rule 14.4)
      - No magic numbers (Rule 14.6, soft via MagicNumber)
      - Javadoc REQUIRED on every class, interface, enum, record (Rule A2.3 +
        D1: every public type carries a class-level summary).
      - Javadoc REQUIRED on public + protected methods (Rule A2.3: public APIs).
      - Javadoc NEVER REQUIRED on private / package-private methods
        (Rule A2.3: "Javadoc only on public APIs ... Never on private methods";
        supersedes earlier 0.1.6 universal-Javadoc reading per P6.0a /
        ADR-0036).
      - When Javadoc IS present anywhere, @param / @return / @throws are
        validated (Rule A2.3 hygiene).

    Severity = error. Build fails on any violation.
-->

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java, properties, xml"/>

    <!-- Honour @SuppressWarnings("checkstyle:checkname") on methods,
         constructors, fields and types so genuine edge-cases (e.g.
         record canonical constructors > 6 components) can opt out
         in a localised, reviewable way without weakening the
         project-wide gate. -->
    <module name="SuppressWarningsFilter"/>

    <!-- ASCII only: forbid non-ASCII characters in source files. -->
    <module name="RegexpSingleline">
        <property name="format" value="[^\x00-\x7F]"/>
        <property name="message" value="Non-ASCII character (Rule A0.1)."/>
    </module>

    <!-- No tabs. Rule A0.4 demands spaces only. -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- No System.out / System.err (Rule 14.4 / A2.5). -->
    <module name="RegexpSingleline">
        <property name="format" value="System\.(out|err)\.print"/>
        <property name="message" value="Use SLF4J, not System.out/err (Rule 14.4)."/>
    </module>

    <!-- No e.printStackTrace (Rule A2.6). -->
    <module name="RegexpSingleline">
        <property name="format" value="\.printStackTrace\(\)"/>
        <property name="message" value="Log with context, not printStackTrace (Rule A2.6)."/>
    </module>

    <!-- No @Autowired on fields (Rule 14.1 / A4.1). -->
    <module name="RegexpSingleline">
        <property name="format" value="^\s*@Autowired\s*$"/>
        <property name="message" value="Constructor injection only; no field @Autowired (Rule 14.1)."/>
    </module>

    <!-- No TODO without an owner (Rule 14.5). -->
    <module name="RegexpSingleline">
        <property name="format" value="//\s*TODO(?!\(.+\))"/>
        <property name="message" value="TODO must include owner: // TODO(name) ... (Rule 14.5)."/>
    </module>

    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="fileExtensions" value="java"/>
    </module>

    <module name="FileLength">
        <property name="max" value="250"/>
        <property name="severity" value="warning"/>
        <property name="fileExtensions" value="java"/>
    </module>

    <module name="TreeWalker">

        <!-- Companion to the top-level SuppressWarningsFilter: emits
             tree events for every @SuppressWarnings annotation so the
             filter can scope its suppression to the annotated element. -->
        <module name="SuppressWarningsHolder"/>

        <!-- ============================================================ -->
        <!-- Javadoc enforcement (Rule A2.3, supersedes 0.1.6 reading)     -->
        <!-- Public APIs must be doc'd; private methods MUST NOT be.       -->
        <!-- Tracked under P6.0a / ADR-0036.                               -->
        <!-- ============================================================ -->

        <module name="MissingJavadocType">
            <property name="scope" value="protected"/>
            <property name="tokens"
                      value="INTERFACE_DEF, CLASS_DEF, ENUM_DEF, ANNOTATION_DEF, RECORD_DEF"/>
        </module>

        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="allowMissingPropertyJavadoc" value="false"/>
            <property name="ignoreMethodNamesRegex"
                      value="^(equals|hashCode|toString|main)$"/>
        </module>

        <module name="JavadocType">
            <property name="scope" value="protected"/>
        </module>

        <module name="JavadocMethod">
            <property name="accessModifiers" value="public,protected"/>
            <property name="validateThrows" value="true"/>
            <property name="allowMissingParamTags" value="false"/>
            <property name="allowMissingReturnTag" value="false"/>
        </module>

        <module name="JavadocVariable">
            <property name="scope" value="protected"/>
        </module>

        <!-- ============================================================ -->
        <!-- Naming, imports, structure                                    -->
        <!-- ============================================================ -->

        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="ConstantName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="ParameterName"/>

        <module name="AvoidStarImport"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports"/>

        <!-- ============================================================ -->
        <!-- Method / class size guardrails (Rule A2.10 / 14.8)            -->
        <!-- ============================================================ -->

        <module name="MethodLength">
            <property name="max" value="30"/>
            <property name="countEmpty" value="false"/>
            <property name="severity" value="warning"/>
        </module>

        <module name="ParameterNumber">
            <property name="max" value="6"/>
        </module>

        <!-- ============================================================ -->
        <!-- Whitespace / formatting                                       -->
        <!-- ============================================================ -->

        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>
        <module name="LeftCurly"/>
        <module name="NeedBraces"/>
        <module name="RightCurly"/>
        <module name="WhitespaceAround"/>
        <module name="WhitespaceAfter"/>
        <module name="NoWhitespaceBefore"/>

        <!-- ============================================================ -->
        <!-- Misc                                                          -->
        <!-- ============================================================ -->

        <module name="MagicNumber">
            <property name="severity" value="warning"/>
            <property name="ignoreNumbers" value="-1, 0, 1, 2, 100, 1000"/>
        </module>
        <module name="EqualsHashCode"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="StringLiteralEquality"/>
        <module name="MissingSwitchDefault"/>
        <module name="FallThrough"/>
        <module name="ModifierOrder"/>
        <module name="RedundantModifier"/>
        <module name="FinalLocalVariable"/>

    </module>

</module>
